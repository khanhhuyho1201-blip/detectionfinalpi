# Cấu hình driver cảm ứng userspace ADS7846.
# Sửa file này rồi chạy: sudo systemctl restart ads7846-touch
# --- Hướng màn hình (landscape) ---
# Nếu con trỏ đi SAI hướng, thử lật các giá trị 0<->1 theo bảng:
#   • Con trỏ ngược TRÁI-PHẢI  -> đổi TS_INVERT_X
#   • Con trỏ ngược TRÊN-DƯỚI  -> đổi TS_INVERT_Y
#   • Di ngang mà con trỏ chạy dọc (và ngược lại) -> đổi TS_SWAP_XY
TS_SWAP_XY=1
TS_INVERT_X=0
TS_INVERT_Y=1
# --- Hiệu chỉnh AFFINE 6 tham số (ưu tiên cao nhất, chính xác nhất) ---
# sx = A*rawX + B*rawY + C ; sy = D*rawX + E*rawY + F. Tính từ 5 điểm hiệu chỉnh,
# kiểm định chéo LOO ~7px (~1mm). Xử lý cả xoay/nghiêng nên chính xác hơn min/max.
TS_AFFINE=0.00014836457,-0.1272363,506.70632,0.085365043,0.00013835394,-16.760216
# --- Dải ADC (chỉ dùng khi KHÔNG có TS_AFFINE; giữ lại để dự phòng) ---
TS_CAL_X_MIN=162
TS_CAL_X_MAX=3951
TS_CAL_Y_MIN=254
TS_CAL_Y_MAX=3878
# --- Độ phân giải màn hình ---
TS_SCREEN_W=480
TS_SCREEN_H=320
# --- Lọc / hiệu năng ---
# SETTLE_SAMPLES: bỏ qua vài điểm nhiễu đầu mỗi lần chạm (chống lệch khi vừa kéo xong).
# SMOOTHING vừa phải để bớt rung mà không quá trễ.
TS_POLL_HZ=90
TS_SAMPLES=16
TS_MAX_STD=45
TS_SMOOTHING=0.40
TS_RELEASE_DEBOUNCE=4
TS_SETTLE_SAMPLES=2
TS_DEBUG=0
TS_SPI_HZ=1000000
